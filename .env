ENV=development
LOG_LEVEL=INFO

# Cấu hình LLM Provider bạn muốn dùng (Ví dụ chọn dùng OpenAI)
LLM_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL_NAME=gemini-2.5-flash

# Nếu muốn test bằng CPU hoặc ép chạy GPU CUDA
USE_CUDA=false

# Cấu hình đường dẫn kết nối API dịch thuật EnViT5 nội bộ của bạn
ENVIT5_API_URL=https://subplot-strep-ragweed.ngrok-free.dev/predict